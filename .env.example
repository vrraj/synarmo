LOCAL_MODELS_CACHE=~/models/synarmo                  # Local GGUF model cache
SYNARMO_MODEL_REPO_ID=QuantFactory/Llama-3.2-1B-GGUF # HF repo for auto-download
SYNARMO_MODEL=Llama-3.2-1B.Q4_K_M.gguf               # GGUF filename or local path

SYNARMO_CONTEXT_WINDOW=4096      # llama.cpp n_ctx token window
SYNARMO_N_GPU_LAYERS=-1          # -1 all GPU layers, 0 CPU-only
SYNARMO_LLAMA_VERBOSE=0          # 1 prints native llama.cpp diagnostics

SYNARMO_MAX_SUGGESTIONS=3        # Suggestions returned
SYNARMO_MAX_TOKENS=5             # Max generated tokens per candidate
SYNARMO_MAX_SUGGESTION_WORDS=2   # Max words shown per suggestion
SYNARMO_TEMPERATURE=0.6          # Starter-token sampling randomness
SYNARMO_TOP_P=0.95               # Starter-token nucleus sampling
SYNARMO_CONTINUATION_TEMPERATURE=0.5 # Continuation sampling randomness
SYNARMO_CONTINUATION_TOP_P=0.9   # Continuation nucleus sampling
SYNARMO_CONTINUATION_TOP_K=20    # Advanced continuation top-k limit; 0 disables
SYNARMO_LOGPROB_POOL=24          # Starter-token pool size
