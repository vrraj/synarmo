# Local GGUF models live here. Keep this directory out of git.
LOCAL_MODELS_CACHE=~/models/synarmo

# Number of suggestions returned by default.
SYNARMO_MAX_SUGGESTIONS=3

# Optional default model file for llama.cpp. Relative paths are resolved from
# LOCAL_MODELS_CACHE; absolute paths are used as-is.
# SYNARMO_MODEL_PATH=Llama-3.2-1B-Instruct-Q4_K_M.gguf
