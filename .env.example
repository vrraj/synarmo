# Local GGUF models live here. Keep this directory out of git.
LOCAL_MODELS_CACHE=~/models/synarmo

# Number of suggestions returned by default.
SYNARMO_MAX_SUGGESTIONS=3

# Hugging Face GGUF model for llama.cpp. When SYNARMO_MODEL_REPO_ID is set,
# llama-cpp-python checks LOCAL_MODELS_CACHE and downloads SYNARMO_MODEL there
# if it is missing.
SYNARMO_MODEL_REPO_ID=hugging-quants/Llama-3.2-1B-Instruct-Q4_K_M-GGUF
SYNARMO_MODEL=llama-3.2-1b-instruct-q4_k_m.gguf
#
# You can also set SYNARMO_MODEL to a local GGUF file. Relative paths are
# resolved from LOCAL_MODELS_CACHE; absolute paths are used as-is.
# SYNARMO_MODEL=TinyLlama-1.1B-Chat-v1.0.Q4_K_M.gguf
#
# Legacy alias, still supported:
# SYNARMO_MODEL_PATH=Llama-3.2-1B-Instruct-Q4_K_M.gguf
