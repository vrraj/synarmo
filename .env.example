# Local GGUF model cache.
LOCAL_MODELS_CACHE=~/models/synarmo

# Default number of suggestions.
SYNARMO_MAX_SUGGESTIONS=3

# llama.cpp GPU layer offload.
# This example assumes an Apple Silicon Mac with one integrated Metal GPU.
# -1 offloads all possible model layers to that GPU.
# Use 0 for CPU-only systems or when debugging GPU issues.
# Positive values offload only that many model layers. This is not the number
# of GPUs; Apple M2 has one integrated Metal GPU.
SYNARMO_N_GPU_LAYERS=-1

# Model downloaded by the llama-cpp backend if it is missing from the cache.
SYNARMO_MODEL_REPO_ID=QuantFactory/Llama-3.2-1B-GGUF
SYNARMO_MODEL=Llama-3.2-1B.Q4_K_M.gguf
