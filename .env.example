# Local GGUF model cache
LOCAL_MODELS_CACHE=~/models/synarmo
# HF repo for auto-download
SYNARMO_MODEL_REPO_ID=QuantFactory/Llama-3.2-1B-GGUF
# GGUF filename or local path
SYNARMO_MODEL=Llama-3.2-1B.Q4_K_M.gguf

# llama.cpp n_ctx token window
SYNARMO_CONTEXT_WINDOW=4096
# -1 all GPU layers, 0 CPU-only
SYNARMO_N_GPU_LAYERS=-1
# 1 prints native llama.cpp diagnostics
SYNARMO_LLAMA_VERBOSE=0

# Suggestions returned
SYNARMO_MAX_SUGGESTIONS=3
# Max generated tokens per candidate
SYNARMO_MAX_TOKENS=5
# Max words shown per suggestion
SYNARMO_MAX_SUGGESTION_WORDS=2
# Starter-token sampling randomness (logprob-based starter selection keeps this low)
SYNARMO_TEMPERATURE=0
# Starter-token nucleus sampling cutoff
SYNARMO_TOP_P=1
# Continuation sampling randomness
SYNARMO_CONTINUATION_TEMPERATURE=0.5
# Continuation nucleus sampling cutoff
SYNARMO_CONTINUATION_TOP_P=0.9
# Advanced continuation top-k limit; 0 disables
SYNARMO_CONTINUATION_TOP_K=20
# 1 enables phrase-level scores but adds latency; 0 is faster starter-token scoring
SYNARMO_PHRASE_LOGPROBS=0
# Starter-token pool size
SYNARMO_LOGPROB_POOL=24

